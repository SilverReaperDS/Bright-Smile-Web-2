# =============================================================
# .gitignore — Bright Smile Web (React + Node.js/Express + MongoDB Atlas)
# =============================================================

# -------------------------------------------------------------
# 1. Dependencies
# -------------------------------------------------------------
node_modules/
src/backend/node_modules/
src/server/node_modules/

# -------------------------------------------------------------
# 2. Environment Variables
#    Contains sensitive secrets: MONGO_URI, JWT_SECRET, etc.
#    NEVER commit these files.
# -------------------------------------------------------------
.env
.env.local
.env.development
.env.production
.env.test
.env.*.local
src/backend/.env
src/backend/.env.local
src/backend/.env.*.local

# -------------------------------------------------------------
# 3. Build Output
# -------------------------------------------------------------
/build
/dist
src/backend/dist/
src/server/dist/

# -------------------------------------------------------------
# 4. Logs
# -------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
logs/

# -------------------------------------------------------------
# 5. OS Files
# -------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# -------------------------------------------------------------
# 6. Editor / IDE Files
# -------------------------------------------------------------
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp

# -------------------------------------------------------------
# 7. Runtime / Temp Files
# -------------------------------------------------------------
*.pid
*.seed
*.pid.lock
.npm
.eslintcache
.cache/
.parcel-cache/
*.tsbuildinfo

# -------------------------------------------------------------
# 8. Local Data Files
#    src/server/users.json is a local JSON user store used
#    during development — not needed in the repository.
# -------------------------------------------------------------
src/server/users.json

# -------------------------------------------------------------
# 9. package-lock.json
#    This project uses npm, so package-lock.json is intentionally
#    kept and committed to ensure reproducible installs.
#    (Do NOT add package-lock.json here unless switching to yarn.)
# -------------------------------------------------------------